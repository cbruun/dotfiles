{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5-nano",
  "autoupdate": false,
  "permission": {
    "edit": "ask",
    "doom_loop": "ask",
    "external_directory": "ask",
    "webfetch": "ask",
    "bash": {
      // default to ask
      "*": "ask",

      // allow: metadata / low-risk inspection
      "column *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "pwd *": "allow",
      "sort *": "allow",
      "tree *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "whoami *": "allow",

      // ask: reads / writes / extraction / transforms
      "awk *": "ask",
      "base64 *": "ask",
      "cat *": "ask",
      "cp *": "ask",
      "diff *": "ask",
      "echo *": "ask",
      "grep *": "ask",
      "head *": "ask",
      "jq *": "ask",
      "mkdir *": "ask",
      "rg *": "ask",
      "sed *": "ask",
      "tail *": "ask",
      "yq *": "ask",

      // ask: network
      "curl *": "ask",
    },
  },
}
