{
  // Theming
  "icon_theme": "Catppuccin Macchiato",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "VSCode Dark Modern"
  },

  // Fonts
  "ui_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_line_height": { "custom": 1.333 },
  "buffer_font_size": 18.0,

  // Privacy
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // AI
  "agent": {
    "enabled": true,
    "button": true,
    "model_parameters": []
  },
  "edit_predictions": {
    "mode": "subtle"
  },
  "show_edit_predictions": true,

  // Keybinds
  "base_keymap": "VSCode",

  // UI
  "fast_scroll_sensitivity": 3.0,
  "scroll_sensitivity": 2.0,

  "minimap": {
    "show": "auto"
  },

  "show_wrap_guides": true,
  "wrap_guides": [120],

  // Git
  "git_panel": {
    "tree_view": true
  },

  // Others
  "file_types": {},
  "features": {
    "edit_prediction_provider": "copilot"
  },

  // Language specific
  "languages": {
    "Terraform": {
      "format_on_save": "on" // Match your VS Code terraform format-on-save. :contentReference[oaicite:11]{index=11}
    },
    "YAML": {
      "format_on_save": "on" // Use redhat/yaml server via Zed’s YAML support.
    },
    "Shell Script": {
      "format_on_save": "off" // Often opinionated; disable if you prefer manual.
    },
    "Markdown": {
      "remove_trailing_whitespace_on_save": false // Keeps trailing spaces when you need hard wraps. :contentReference[oaicite:12]{index=12}
    },
    "JSON": {
      "format_on_save": "on" // JSONC/JSON format via built-ins/Prettier notes. :contentReference[oaicite:13]{index=13}
    },
    "TOML": {
      "format_on_save": "on" // Uses Taplo formatter by default.
    }
  }
}
